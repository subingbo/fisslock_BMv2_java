# 复制为 env.server 并按需修改
#   cp scripts/env.server.example scripts/env.server
#   source scripts/env.server

# 你的 Ubuntu 实验机（SSH 登录用）
export FISSLOCK_SERVER=192.168.43.110
export FISSLOCK_USER=subingbo

# 项目路径（服务器上的实际目录，默认 home 下）
export FISSLOCK_ROOT=/home/subingbo/fisslock
export P4_BMV2_ROOT="${FISSLOCK_ROOT}/switch/p4_bmv2"

# p4dev: source ~/p4setup.bash 或 tutorials 里的 p4c
export PATH=/home/subingbo/tutorials/p4c-stable/build:/usr/local/bin:${PATH}
# optional: source /home/subingbo/p4setup.bash

# 测试发包网卡（本机 veth，勿改成 192.168.43.110）
export FISSLOCK_TEST_IFACE=veth-inject
export FISSLOCK_PCAP_DIR="${P4_BMV2_ROOT}/build/pcap"
